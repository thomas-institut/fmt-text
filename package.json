    "url": "https://github.com/thomas-institut/fmt-text/issues"
  },
  "homepage": "https://github.com/thomas-institut/fmt-text#readme",
  "dependencies": {
    "@thomas-inst/optionschecker": "^1.1.4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/node": "^24.0.10",
    "rollup": "4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
