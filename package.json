{
  "name": "@thomas-inst/fmt-text",
  "version": "1.1.0",
  "description": "",
  "scripts": {
    "test": "vitest run",
    "prebuild": "rm -rf dist",
    "build": "rollup -c"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./FmtText": {
      "import": "./dist/FmtText.js",
      "require": "./dist/FmtText.cjs",
      "types": "./dist/FmtText.d.ts"
    },
    "./FmtTextTokenType": {
      "import": "./dist/FmtTextTokenType.js",
      "require": "./dist/FmtTextTokenType.cjs",
      "types": "./dist/FmtTextTokenType.d.ts"
    },
    "./FontSize": {
      "import": "./dist/FontSize.js",
      "require": "./dist/FontSize.cjs",
      "types": "./dist/FontSize.d.ts"
    },
    "./FontStyle": {
      "import": "./dist/FontStyle.js",
      "require": "./dist/FontStyle.cjs",
      "types": "./dist/FontStyle.d.ts"
    },
    "./FontWeight": {
      "import": "./dist/FontWeight.js",
      "require": "./dist/FontWeight.cjs",
      "types": "./dist/FontWeight.d.ts"
    },
    "./MarkType": {
      "import": "./dist/MarkType.js",
      "require": "./dist/MarkType.cjs",
      "types": "./dist/MarkType.d.ts"
    },
    "./ParagraphStyle": {
      "import": "./dist/ParagraphStyle.js",
      "require": "./dist/ParagraphStyle.cjs",
      "types": "./dist/ParagraphStyle.d.ts"
    },
    "./VerticalAlign": {
      "import": "./dist/VerticalAlign.js",
      "require": "./dist/VerticalAlign.cjs",
      "types": "./dist/VerticalAlign.d.ts"
    },
    "./FmtTextRenderer": {
      "import": "./dist/Renderer/FmtTextRenderer.js",
      "require": "./dist/Renderer/FmtTextRenderer.cjs",
      "types": "./dist/Renderer/FmtTextRenderer.d.ts"
    },
    "./HtmlRenderer": {
      "import": "./dist/Renderer/HtmlRenderer.js",
      "require": "./dist/Renderer/HtmlRenderer.cjs",
      "types": "./dist/Renderer/HtmlRenderer.d.ts"
    },
    "./AsyncFmtTextRenderer": {
      "import": "./dist/Renderer/AsyncFmtTextRenderer.js",
      "require": "./dist/Renderer/AsyncFmtTextRenderer.cjs",
      "types": "./dist/Renderer/AsyncFmtTextRenderer.d.ts"
    }
